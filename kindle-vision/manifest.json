{
  "manifest_version": 3,
  "name": "Kindle 即時翻譯",
  "version": "2.0.0",
  "description": "截圖翻譯 Kindle Cloud Reader 頁面為繁體中文",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://read.amazon.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://read.amazon.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kindle 即時翻譯"
  }
}
